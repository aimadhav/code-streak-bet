# Stellar Network Configuration
VITE_STELLAR_NETWORK=testnet
# Options: testnet, mainnet

# Smart Contract Address (deployed on testnet)
VITE_CHALLENGE_CONTRACT_ADDRESS=CC5WC6EUFXOGSI52OXTYVY5U6YYVYR7IVH6NQ2NM25EZHBY6OQVXGSVO

# Platform Fee Address (contract-deployer address for testnet)
VITE_PLATFORM_FEE_ADDRESS=GCB2Z3XA2OB4HFCZFUSZPXBT3PFCBT6NV5UTELE2DKCNOSV7K4VTIKVM

# LeetCode API Configuration
VITE_LEETCODE_API_URL=https://leetcode-api-pied.vercel.app
# Use http://localhost:8000 for local development

# API Configuration
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Rate Limiting
VITE_RATE_LIMIT_MAX_REQUESTS=20
VITE_RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=false
VITE_ENABLE_PROGRESS_MONITORING=true

# Progress Monitoring Configuration
VITE_PROGRESS_CHECK_INTERVAL=300000
# 300000ms = 5 minutes (how often to check user progress)

VITE_AUTO_START_MONITORING=true
# Automatically start monitoring active challenges on wallet connect

# Oracle Service URL (for production backend)
# VITE_ORACLE_SERVICE_URL=https://your-oracle-service.com
